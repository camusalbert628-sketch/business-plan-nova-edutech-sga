</div>
<div class="stat-item">
<div class="stat-value">98%</div>
<div class="stat-label">Satisfaction</div>
</div>
</div>
</div>
<!-- Right Card - STUDY GENIUS ACADEMY -->
<div class="card animate-in delay-2">
<div>
<div class="card-header">
