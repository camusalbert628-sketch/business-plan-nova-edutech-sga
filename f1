                    </div>
</div>
</div>
<!-- Decorative Elements -->
<div class="floating-icon floating-icon-1">
<i class="fas fa-lightbulb"></i>
</div>
<div class="floating-icon floating-icon-2">
<i class="fas fa-chart-line"></i>
</div>
</div>
</div>
</body>
</html>
